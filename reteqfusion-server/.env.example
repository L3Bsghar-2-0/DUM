# MQTT
MQTT_HOST=your-broker.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=python-server
MQTT_PASSWORD=replace_me
MQTT_CLIENT_ID=reteqfusion-server-01
MQTT_TLS=true
MQTT_KEEPALIVE=60

# Database
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=reteqfusion
POSTGRES_USER=reteq
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql://reteq:replace_me@timescaledb:5432/reteqfusion

# Grafana
GRAFANA_ADMIN_PASSWORD=replace_me

# App
LOG_LEVEL=INFO
API_PORT=8000

# MQ-2 thresholds
MQ2_SMOKE_ALARM_PPM=1000
MQ2_HAZARD_PPM=3000
