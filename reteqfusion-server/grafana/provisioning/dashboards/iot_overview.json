      "title": "Device Status",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "online":  { "color": "green", "index": 0, "text": "online" } } },
                  { "type": "value", "options": { "offline": { "color": "red",   "index": 1, "text": "offline" } } }
