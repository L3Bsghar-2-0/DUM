        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "rawSql": "SELECT device_id, status, last_seen, rssi, fw_version FROM device_status ORDER BY device_id"
        }
      ]
    },
