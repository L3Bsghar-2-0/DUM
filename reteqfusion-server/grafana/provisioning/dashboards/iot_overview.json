          "refId": "A",
          "format": "time_series",
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "rawSql": "SELECT time_bucket('1 minute', time) AS \"time\", 'messages' AS metric, COUNT(*) AS value FROM telemetry WHERE $__timeFilter(time) GROUP BY 1 ORDER BY 1"
