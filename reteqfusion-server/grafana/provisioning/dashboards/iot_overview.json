      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "msg/min",
