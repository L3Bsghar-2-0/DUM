    {
      "id": 1,
      "title": "Live Temperature (°C)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "red", "value": 60 }
            ]
          },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "rawSql": "SELECT time AS \"time\", device_id AS metric, value FROM telemetry WHERE sensor_type='dht22' AND reading_key='temperature' AND $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
