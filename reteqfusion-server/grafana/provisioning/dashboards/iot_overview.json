      "id": 13,
      "title": "Recent Anomalies",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 47 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "anomaly_type" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "HAZARD_ALARM":  { "color": "red",    "index": 0, "text": "HAZARD_ALARM" } } },
                  { "type": "value", "options": { "SMOKE_ALARM":   { "color": "orange", "index": 1, "text": "SMOKE_ALARM" } } },
                  { "type": "value", "options": { "HEAT_ALERT":    { "color": "red",    "index": 2, "text": "HEAT_ALERT" } } },
                  { "type": "value", "options": { "HIGH_HUMIDITY": { "color": "orange", "index": 3, "text": "HIGH_HUMIDITY" } } },
                  { "type": "value", "options": { "SPIKE":         { "color": "yellow", "index": 4, "text": "SPIKE" } } },
                  { "type": "value", "options": { "DROPOUT":       { "color": "purple", "index": 5, "text": "DROPOUT" } } },
                  { "type": "value", "options": { "STUCK_SENSOR":  { "color": "blue",   "index": 6, "text": "STUCK_SENSOR" } } },
                  { "type": "value", "options": { "DRIFT":         { "color": "blue",   "index": 7, "text": "DRIFT" } } }
