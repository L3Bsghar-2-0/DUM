    {
      "id": 4,
      "title": "Comfort Index",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "comfortable": { "color": "green",  "index": 0, "text": "comfortable" } } },
            { "type": "value", "options": { "hot":         { "color": "red",    "index": 1, "text": "hot" } } },
            { "type": "value", "options": { "cold":        { "color": "blue",   "index": 2, "text": "cold" } } },
            { "type": "value", "options": { "humid":       { "color": "orange", "index": 3, "text": "humid" } } },
            { "type": "value", "options": { "dry":         { "color": "yellow", "index": 4, "text": "dry" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "rawSql": "SELECT comfort_index AS value FROM telemetry WHERE sensor_type='dht22' AND comfort_index IS NOT NULL ORDER BY time DESC LIMIT 1"
        }
      ]
    },
